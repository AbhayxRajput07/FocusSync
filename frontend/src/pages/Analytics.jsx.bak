import React, { useState, useEffect } from 'react';
import { Line, Bar, Doughnut } from 'react-chartjs-2';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  Calendar, TrendingUp, Target, AlertTriangle, Clock, 
  ChevronDown, ChevronUp, Activity, PieChart, BarChart3 
} from 'lucide-react';
import {
  Chart as ChartJS,
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  BarElement,
  ArcElement,
  Title,
  Tooltip,
  Legend,
  Filler
} from 'chart.js';

ChartJS.register(
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  BarElement,
  ArcElement,
  Title,
  Tooltip,
  Legend,
  Filler
);

// Framer Motion entry variants
const containerVariants = {
  hidden: { opacity: 0 },
  visible: {
    opacity: 1,
    transition: { staggerChildren: 0.05, delayChildren: 0.02 }
  }
};

const itemVariants = {
  hidden: { opacity: 0, y: 15 },
  visible: { opacity: 1, y: 0, transition: { duration: 0.4, ease: 'easeOut' } }
};

const useAnimatedCounter = (target, duration = 800) => {
  const [count, setCount] = useState(0);

  useEffect(() => {
    if (target <= 0) {
      setCount(0);
      return;
    }
    const increment = target / (duration / 16);
    let current = 0;
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        setCount(target);
        clearInterval(timer);
      } else {
        setCount(Math.floor(current));
      }
    }, 16);
    return () => clearInterval(timer);
  }, [target, duration]);

  return count;
};

const Analytics = () => {
  const [dateRange, setDateRange] = useState('week'); // 'today' | 'week' | 'month' | 'all'
  const [sessions, setSessions] = useState([]);
  const [expandedSession, setExpandedSession] = useState(null);
  const [streak, setStreak] = useState({ current: 0, longest: 0 });

  useEffect(() => {
    const savedSessions = JSON.parse(localStorage.getItem('fs_sessions') || '[]');
    setSessions(savedSessions);
    const savedStreak = JSON.parse(localStorage.getItem('fs_streak') || '{"current":0,"longest":0}');
    setStreak(savedStreak);
  }, []);

  const getFilteredSessions = () => {
    const now = Date.now();
    const dayMs = 86400000;
    return sessions.filter(s => {
      const sessionTime = s.startTime;
      if (dateRange === 'today') return new Date(sessionTime).toDateString() === new Date().toDateString();
      if (dateRange === 'week') return now - sessionTime < 7 * dayMs;
      if (dateRange === 'month') return now - sessionTime < 30 * dayMs;
      return true;
    });
  };

  const filteredSessions = getFilteredSessions();
  const totalFocusTime = filteredSessions.reduce((sum, s) => sum + (s.focusMinutes || 0), 0);
  const avgScore = filteredSessions.length > 0
    ? Math.round(filteredSessions.reduce((sum, s) => sum + s.finalScore, 0) / filteredSessions.length)
    : 0;
  const totalSessions = filteredSessions.length;

  const animatedFocusTime = useAnimatedCounter(totalFocusTime);
  const animatedScore = useAnimatedCounter(avgScore);
  const animatedSessionCount = useAnimatedCounter(totalSessions);

  // Focus trend line chart data
  const getLast7Days = () => {
    const days = [];
    for (let i = 6; i >= 0; i--) {
      const date = new Date(Date.now() - i * 86400000);
      days.push(date.toLocaleDateString('en-US', { weekday: 'short' }));
    }
    return days;
  };

  const last7DaysLabels = getLast7Days();
  const dailyScores = last7DaysLabels.map((_, idx) => {
    const date = new Date(Date.now() - (6 - idx) * 86400000);
    const daySessions = sessions.filter(s => new Date(s.startTime).toDateString() === date.toDateString());
    if (daySessions.length === 0) return null;
    return Math.round(daySessions.reduce((sum, s) => sum + s.finalScore, 0) / daySessions.length);
  });

  const trendLineData = {
    labels: last7DaysLabels,
    datasets: [{
      label: 'Focus Score',
      data: dailyScores,
      borderColor: '#4f46e5', // INDIGO-600
      backgroundColor: 'rgba(79, 70, 229, 0.1)',
      fill: true,
      tension: 0.4,
      pointRadius: 4,
      pointHoverRadius: 6,
      spanGaps: true
    }]
  };

  const stackedBarData = {
    labels: last7DaysLabels,
    datasets: [
      {
        label: 'Focus Minutes',
        data: last7DaysLabels.map((_, idx) => {
          const date = new Date(Date.now() - (6 - idx) * 86400000);
          const daySessions = sessions.filter(s => new Date(s.startTime).toDateString() === date.toDateString());
          return daySessions.reduce((sum, s) => sum + (s.focusMinutes || 0), 0);
        }),
        backgroundColor: '#4f46e5',
        borderRadius: 4,
      },
      {
        label: 'Distraction Minutes',
        data: last7DaysLabels.map((_, idx) => {
          const date = new Date(Date.now() - (6 - idx) * 86400000);
          const daySessions = sessions.filter(s => new Date(s.startTime).toDateString() === date.toDateString());
          return daySessions.reduce((sum, s) => sum + (s.distractionMinutes || 0), 0);
        }),
        backgroundColor: '#cbd5e1', // SLATE-300
        borderRadius: 4,
      }
    ]
  };

  const subjectBreakdown = {};
  filteredSessions.forEach(s => {
    const subject = s.subject || 'Uncategorized';
    subjectBreakdown[subject] = (subjectBreakdown[subject] || 0) + (s.focusMinutes + s.distractionMinutes);
  });

  const donutData = {
    labels: Object.keys(subjectBreakdown),
    datasets: [{
      data: Object.values(subjectBreakdown),
      backgroundColor: [
        '#4f46e5', '#0ea5e9', '#f59e0b', '#10b981', '#8b5cf6', '#94a3b8'
      ],
      borderWidth: 2,
      borderColor: '#ffffff'
    }]
  };

  const getDistractionHeatmap = () => {
    const heatmap = Array(7).fill(0).map(() => Array(24).fill(0));
    sessions.forEach(s => {
      const date = new Date(s.startTime);
      const day = date.getDay();
      const hour = date.getHours();
      heatmap[day][hour] += s.distractionCount || 0;
    });
    return heatmap;
  };

  const heatmapData = getDistractionHeatmap();
  const maxDistractions = Math.max(...heatmapData.flat());

  let highestRisk = { day: 0, hour: 0, count: 0 };
  heatmapData.forEach((dayData, dayIdx) => {
    dayData.forEach((count, hourIdx) => {
      if (count > highestRisk.count) {
        highestRisk = { day: dayIdx, hour: hourIdx, count };
      }
    });
  });

  const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  const highestRiskText = highestRisk.count > 0 
    ? `${dayNames[highestRisk.day]}s at ${highestRisk.hour}:00`
    : 'No data yet';

  const focusDebt = filteredSessions.reduce((sum, s) => sum + (s.distractionMinutes || 0), 0);
  const debtThreshold = 30;

  // Global Chart Configurations
  const tooltipStyles = {
    backgroundColor: '#ffffff',
    titleColor: '#0f172a',
    bodyColor: '#475569',
    borderColor: '#e2e8f0',
    borderWidth: 1,
    padding: 12,
    boxPadding: 6,
    bodyFont: { family: "'Inter', sans-serif" },
    titleFont: { family: "'Inter', sans-serif", weight: 'bold' }
  };

  const lineChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: tooltipStyles
    },
    scales: {
      x: {
        grid: { display: false },
        ticks: { color: '#64748b', font: { family: "'Inter', sans-serif" } },
        border: { display: false }
      },
      y: {
        min: 0,
        max: 100,
        grid: { color: '#f1f5f9' },
        ticks: { color: '#94a3b8', font: { family: "'Inter', sans-serif" } },
        border: { display: false }
      }
    }
  };

  const barChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        labels: { boxWidth: 10, color: '#64748b', font: { family: "'Inter', sans-serif" } }
      },
      tooltip: tooltipStyles
    },
    scales: {
      x: {
        stacked: true,
        grid: { display: false },
        ticks: { color: '#64748b', font: { family: "'Inter', sans-serif" } },
        border: { display: false }
      },
      y: {
        stacked: true,
        grid: { color: '#f1f5f9' },
        ticks: { color: '#94a3b8', font: { family: "'Inter', sans-serif" } },
        border: { display: false }
      }
    }
  };

  const donutOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        position: 'right',
        labels: { color: '#64748b', padding: 15, boxWidth: 10, font: { family: "'Inter', sans-serif" } }
      },
      tooltip: tooltipStyles
    }
  };

  const formatTime = (minutes) => {
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return h > 0 ? `${h}h ${m}m` : `${m}m`;
  };

  const getScoreBadgeStyles = (score) => {
    if (score >= 80) return 'bg-emerald-50 text-emerald-700 border-emerald-200';
    if (score >= 60) return 'bg-amber-50 text-amber-700 border-amber-200';
    return 'bg-rose-50 text-rose-700 border-rose-200';
  };

  return (
    <motion.div
      variants={containerVariants}
      initial="hidden"
      animate="visible"
      className="space-y-8 pb-24 font-sans"
    >
      {/* Header */}
      <motion.div variants={itemVariants} className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <h1 className="text-3xl font-bold tracking-tight text-slate-900">Analytics Review</h1>
          <p className="text-sm font-medium text-slate-500 mt-1">Deep insights and data on your workflow</p>
        </div>
        
        {/* Modern Date Toggle */}
        <div className="flex items-center gap-1 rounded-xl border border-slate-200 bg-slate-50 p-1 shadow-sm">
          {['today', 'week', 'month', 'all'].map(range => (
            <button
              key={range}
              onClick={() => setDateRange(range)}
              className={`px-4 py-1.5 rounded-lg text-sm font-semibold transition-all ${
                dateRange === range 
                  ? 'bg-white text-indigo-700 shadow-sm border border-slate-200/50' 
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
              }`}
            >
              {range.charAt(0).toUpperCase() + range.slice(1)}
            </button>
          ))}
        </div>
      </motion.div>
      
      {/* 4 Summary Metric Cards */}
      <motion.div variants={containerVariants} className="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <motion.div variants={itemVariants} whileHover={{ y: -3 }} className="flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div className="flex items-center justify-between">
            <span className="text-sm font-semibold text-slate-500">Focus Time</span>
            <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50">
              <Clock className="w-5 h-5 text-indigo-600" />
            </div>
          </div>
          <div className="mt-4">
            <div className="text-3xl font-bold tracking-tight text-slate-900">{formatTime(animatedFocusTime)}</div>
          </div>
        </motion.div>

        <motion.div variants={itemVariants} whileHover={{ y: -3 }} className="flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div className="flex items-center justify-between">
            <span className="text-sm font-semibold text-slate-500">Avg Score</span>
            <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50">
              <TrendingUp className="w-5 h-5 text-emerald-600" />
            </div>
          </div>
          <div className="mt-4 flex items-end gap-1">
            <div className="text-3xl font-bold tracking-tight text-slate-900">{animatedScore}</div>
            <span className="text-sm font-bold text-slate-400 mb-1">/ 100</span>
          </div>
        </motion.div>

        <motion.div variants={itemVariants} whileHover={{ y: -3 }} className="flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div className="flex items-center justify-between">
            <span className="text-sm font-semibold text-slate-500">Total Sessions</span>
            <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-sky-50">
              <Target className="w-5 h-5 text-sky-600" />
            </div>
          </div>
          <div className="mt-4">
            <div className="text-3xl font-bold tracking-tight text-slate-900">{animatedSessionCount}</div>
          </div>
        </motion.div>

        <motion.div variants={itemVariants} whileHover={{ y: -3 }} className="flex flex-col justify-between rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div className="flex items-center justify-between">
            <span className="text-sm font-semibold text-slate-500">Best Streak</span>
            <div className="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-50">
              <Calendar className="w-5 h-5 text-amber-600" />
            </div>
          </div>
          <div className="mt-4 flex items-center gap-2">
            <div className="text-3xl font-bold tracking-tight text-slate-900">{streak.longest}</div>
            <span className="text-xs font-semibold px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">Days</span>
          </div>
        </motion.div>
      </motion.div>
      
      {/* Charts Row */}
      <motion.div variants={containerVariants} className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl">
          <div className="flex items-center justify-between mb-6">
            <h2 className="text-lg font-bold text-slate-900">Performance Trend</h2>
            <Activity className="w-5 h-5 text-slate-400" />
          </div>
          <div className="h-64">
            <Line data={trendLineData} options={lineChartOptions} />
          </div>
        </motion.div>
        
        <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl">
          <div className="flex items-center justify-between mb-6">
            <h2 className="text-lg font-bold text-slate-900">Output Analysis</h2>
            <BarChart3 className="w-5 h-5 text-slate-400" />
          </div>
          <div className="h-64">
            <Bar data={stackedBarData} options={barChartOptions} />
          </div>
        </motion.div>
      </motion.div>
      
      {/* Subject Breakdown & Focus Debt Row */}
      <motion.div variants={containerVariants} className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl flex flex-col">
          <div className="flex items-center justify-between mb-6">
            <h2 className="text-lg font-bold text-slate-900">Subject Distribution</h2>
            <PieChart className="w-5 h-5 text-slate-400" />
          </div>
          <div className="flex-1 flex items-center justify-center">
            {Object.keys(subjectBreakdown).length > 0 ? (
              <div className="h-64 w-full">
                <Doughnut data={donutData} options={donutOptions} />
              </div>
            ) : (
              <div className="flex flex-col items-center justify-center text-slate-400 h-full gap-2">
                <PieChart className="w-8 h-8 opacity-50" />
                <span className="text-sm font-medium">No categorical data to display</span>
              </div>
            )}
          </div>
        </motion.div>
        
        <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl">
          <div className="flex items-center justify-between mb-6">
            <h2 className="text-lg font-bold text-slate-900">Focus Debt Threshold</h2>
            <span className="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-xs font-bold">{debtThreshold}m limit</span>
          </div>
          <div className="space-y-6">
            <div className="flex flex-col items-center justify-center py-6 border border-slate-100 bg-slate-50 rounded-2xl">
              <div className="text-5xl font-extrabold text-slate-900 tracking-tight">{focusDebt}<span className="text-xl text-slate-400 font-bold ml-1">m</span></div>
              <div className="text-sm font-medium text-slate-500 mt-2">Accumulated distraction minutes</div>
            </div>
            
            <div className="relative pt-2">
              <div className="flex items-center justify-between mb-2">
                <span className="text-xs font-bold text-slate-500 uppercase tracking-wide">Debt Capacity</span>
                <span className="text-xs font-bold text-slate-900">{Math.round((focusDebt / debtThreshold) * 100)}%</span>
              </div>
              <div className="h-3 bg-slate-100 rounded-full overflow-hidden shadow-inner">
                <div 
                  className={`h-full transition-all duration-1000 ${
                    focusDebt >= debtThreshold ? 'bg-rose-500' : 'bg-amber-400'
                  }`}
                  style={{ width: `${Math.min((focusDebt / debtThreshold) * 100, 100)}%` }}
                ></div>
              </div>
            </div>
            
            <AnimatePresence>
              {focusDebt >= debtThreshold && (
                <motion.div 
                  initial={{ opacity: 0, height: 0 }}
                  animate={{ opacity: 1, height: 'auto' }}
                  className="p-4 bg-rose-50 border border-rose-200 rounded-xl overflow-hidden"
                >
                  <div className="flex items-center gap-3 mb-2">
                    <AlertTriangle className="w-5 h-5 text-rose-600" />
                    <span className="font-bold text-rose-800 text-sm">Critical Debt Level</span>
                  </div>
                  <p className="text-xs text-rose-600 font-medium mb-4">You have exceeded standard distraction thresholds. We recommend a strict recovery session.</p>
                  <button className="w-full py-2.5 bg-rose-600 text-white rounded-lg text-sm font-bold shadow-sm hover:bg-rose-700 transition">
                    Start Recovery Drill
                  </button>
                </motion.div>
              )}
            </AnimatePresence>
          </div>
        </motion.div>
      </motion.div>
      
      {/* Distraction Heatmap */}
      <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl">
        <h2 className="text-lg font-bold text-slate-900 mb-5">Vulnerability Heatmap</h2>
        
        <div className="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-xl flex items-start sm:items-center gap-3">
          <div className="mt-0.5 sm:mt-0 flex-shrink-0 bg-white p-2 rounded-lg shadow-sm border border-amber-100">
            <AlertTriangle className="w-5 h-5 text-amber-500" />
          </div>
          <div>
            <span className="text-sm font-semibold text-amber-900 block sm:inline">Identified Risk Window: </span>
            <span className="text-sm font-bold text-amber-700 sm:ml-1">{highestRiskText}</span>
            <p className="text-xs text-amber-600/80 mt-1 font-medium">Plan your strictest focus tools during this timeframe to counteract habitual distractions.</p>
          </div>
        </div>
        
        {/* Heatmap Grid */}
        <div className="overflow-x-auto pb-4">
          <div className="min-w-max" style={{ display: 'grid', gridTemplateColumns: 'auto repeat(24, 1fr)', gap: '4px' }}>
            <div className="col-span-1"></div>
            {Array.from({ length: 24 }, (_, i) => (
              <div key={i} className="text-[10px] font-bold text-slate-400 text-center w-6">{i}</div>
            ))}
            
            {dayNames.map((day, dayIdx) => (
              <React.Fragment key={day}>
                <div className="text-[10px] font-bold text-slate-500 flex items-center pr-4 uppercase tracking-wide">{day}</div>
                {Array.from({ length: 24 }, (_, hourIdx) => {
                  const count = heatmapData[dayIdx][hourIdx];
                  const intensity = maxDistractions > 0 ? count / maxDistractions : 0;
                  // Map directly to rose styling
                  const getHeatmapColor = () => {
                    if (count === 0) return 'bg-slate-50 border-slate-100';
                    if (intensity < 0.3) return 'bg-rose-200 border-rose-200';
                    if (intensity < 0.6) return 'bg-rose-400 border-rose-400';
                    if (intensity < 0.9) return 'bg-rose-500 border-rose-500';
                    return 'bg-rose-600 border-rose-600';
                  };
                  
                  return (
                    <motion.div
                      whileHover={{ scale: 1.2, zIndex: 10 }}
                      key={hourIdx}
                      className={`w-6 h-6 rounded-md border ${getHeatmapColor()} transition-colors cursor-pointer`}
                      title={`${day} ${hourIdx}:00 - ${count} distractions`}
                    ></motion.div>
                  );
                })}
              </React.Fragment>
            ))}
          </div>
        </div>
      </motion.div>
      
      {/* Session History Table */}
      <motion.div variants={itemVariants} className="p-6 bg-white border border-slate-200 shadow-sm rounded-2xl">
        <div className="flex items-center justify-between mb-6">
          <h2 className="text-lg font-bold text-slate-900">Historical Log</h2>
          <span className="text-xs font-semibold px-2 py-1 bg-slate-100 text-slate-500 rounded-md block">
            {filteredSessions.length} Entries
          </span>
        </div>

        {filteredSessions.length > 0 ? (
          <div className="space-y-3">
            {filteredSessions.slice().reverse().map((session, idx) => (
              <motion.div 
                layout
                key={session.id || idx} 
                className="border border-slate-200 bg-white rounded-xl overflow-hidden shadow-sm"
              >
                <button
                  onClick={() => setExpandedSession(expandedSession === session.id ? null : session.id)}
                  className="w-full p-4 flex items-center justify-between hover:bg-slate-50 transition-colors group"
                >
                  <div className="flex flex-wrap sm:flex-nowrap items-center gap-4 sm:gap-6 text-left w-full pr-4">
                    <div className="text-xs font-semibold text-slate-400 min-w-[80px]">
                      {new Date(session.startTime).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' })}
                    </div>
                    <div className="font-bold text-slate-900 truncate w-32 sm:w-48">
                      {session.subject || 'Deep Session'}
                    </div>
                    <div className="flex items-center gap-2 min-w-[100px]">
                      <Clock className="w-3.5 h-3.5 text-slate-400" />
                      <span className="text-sm font-medium text-slate-600">
                        {formatTime((session.focusMinutes || 0) + (session.distractionMinutes || 0))}
                      </span>
                    </div>
                    <div className="hidden sm:block">
                      <span className={`px-2.5 py-1 rounded-full text-xs font-bold border ${getScoreBadgeStyles(session.finalScore)}`}>
                        {session.finalScore} PTS
                      </span>
                    </div>
                    <div className="hidden sm:block text-xs font-bold text-slate-400 ml-auto">
                      {session.distractionCount || 0} alerts
                    </div>
                  </div>
                  <div className="bg-slate-100 p-1.5 rounded-lg group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-colors">
                    {expandedSession === session.id ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
                  </div>
                </button>
                
                <AnimatePresence>
                  {expandedSession === session.id && (
                    <motion.div 
                      initial={{ height: 0, opacity: 0 }}
                      animate={{ height: 'auto', opacity: 1 }}
                      exit={{ height: 0, opacity: 0 }}
                      className="origin-top"
                    >
                      <div className="p-5 bg-slate-50 border-t border-slate-100">
                        <div className="flex flex-col sm:flex-row gap-6">
                            <div className="flex-1 space-y-4">
                              <div>
                                <div className="text-xs font-bold text-slate-400 uppercase tracking-wide mb-3">Minute-by-minute topology</div>
                                <div className="flex flex-wrap gap-1.5">
                                  {Array.from({ length: session.pomodoroLength || Math.min(25, (session.focusMinutes || 25) + (session.distractionMinutes || 0)) }, (_, i) => {
                                    const r = Math.random();
                                    let c = 'bg-emerald-400';
                                    if(r > 0.85) c = 'bg-rose-400';
                                    else if(r > 0.7) c = 'bg-amber-400';
                                    return (
                                      <motion.div
                                        whileHover={{ scale: 1.5 }}
                                        key={i}
                                        className={`w-4 h-4 rounded-sm shadow-sm ${c}`}
                                        title={`Interval Segment ${i + 1}`}
                                      />
                                    );
                                  })}
                                </div>
                              </div>
                            </div>
                            <div className="sm:border-l border-slate-200 sm:pl-6 sm:w-48 flex flex-col justify-center space-y-3">
                                <div>
                                    <span className="block text-[10px] font-bold text-slate-400 uppercase tracking-wide">Focus Ratio</span>
                                    <span className="text-lg font-bold text-slate-900">
                                        {session.focusMinutes && (session.focusMinutes + session.distractionMinutes) > 0 
                                            ? Math.round((session.focusMinutes/(session.focusMinutes + session.distractionMinutes))*100) 
                                            : 0}%
                                    </span>
                                </div>
                                <div>
                                    <span className="block text-[10px] font-bold text-slate-400 uppercase tracking-wide">Interrupts</span>
                                    <span className="text-sm font-bold text-slate-700">{session.distractionCount || 0} times</span>
                                </div>
                            </div>
                        </div>
                      </div>
                    </motion.div>
                  )}
                </AnimatePresence>
              </motion.div>
            ))}
          </div>
        ) : (
          <div className="flex flex-col items-center justify-center py-16 px-4 text-center bg-slate-50 border border-dashed border-slate-200 rounded-xl">
            <div className="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm border border-slate-100 mb-4">
              <Target className="w-8 h-8 text-slate-300" />
            </div>
            <h3 className="text-slate-900 font-bold text-lg">No sessions processed</h3>
            <p className="text-sm text-slate-500 font-medium max-w-sm mt-1">
              Your analytics engine is waiting. Complete a deep work session to populate the data visualizers.
            </p>
          </div>
        )}
      </motion.div>
    </motion.div>
  );
};

export default Analytics;
